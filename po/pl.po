#: data/app.desktop.in:2 data/app.metainfo.xml.in:4 src/application.vala:275
#: src/main.vala:24
msgid "Gapless"
msgstr "Gapless"

#: data/app.desktop.in:3
msgid "Music Player"
msgstr "Odtwarzacz muzyki"

#: data/app.desktop.in:4 data/app.metainfo.xml.in:7
msgid "Play your music elegantly"
msgstr "Eleganckie odtwarzanie muzyki"

#: data/app.desktop.in:11
msgid "music;sound;player;media;audio;playlist;"
msgstr ""
"muzyka;dźwięk;odtwarzacz;media;audio;lista "
"odtwarzania;multimedia;music;gapless;playlist;playlista;plejlista;"

#: data/app.metainfo.xml.in:24
msgid ""
"Gapless (AKA: G4Music) is a light weight music player written in GTK4, "
"focuses on large music collection."
msgstr ""
"Gapless (AKA: G4Music) to lekki odtwarzacz muzyki napisany w GTK4, "
"skupiający się na dużych kolekcjach muzycznych."

#: data/app.metainfo.xml.in:25
msgid "Features"
msgstr "Funkcje"

#: data/app.metainfo.xml.in:27
msgid ""
"Supports most music file types, Samba and any other remote protocols "
"(depends on GIO and GStreamer)."
msgstr ""
"Obsługuje większość typów plików muzycznych, Sambę i inne zdalne protokoły "
"(zależy od GIO i GStreamer)."

#: data/app.metainfo.xml.in:28
msgid ""
"Fast loading and parsing thousands of music files in very few seconds, "
"monitor local changes."
msgstr ""
"Szybkie wczytywanie i analizowanie tysięcy plików muzycznych w kilka sekund, "
"monitorowanie lokalnych zmian."

#: data/app.metainfo.xml.in:29
msgid ""
"Low memory usage for large music collection with album covers (embedded and "
"external), no thumbnail caches to store."
msgstr ""
"Niskie zużycie pamięci dla dużej kolekcji muzycznej z okładkami albumów "
"(osadzonymi i zewnętrznymi), bez pamięci podręcznej miniatur do "
"przechowywania."

#: data/app.metainfo.xml.in:30
msgid ""
"Group and sorts by album/artist/title, shuffle list, full-text searching."
msgstr ""
"Grupowanie i sortowanie według albumu/wykonawcy/utworu, losowe listy i "
"wyszukiwanie pełnotekstowe."

#: data/app.metainfo.xml.in:31
msgid ""
"Fluent adaptive user interface for different screen (Desktop, Tablet, "
"Mobile)."
msgstr ""
"Płynny, adaptacyjny interfejs dla różnych ekranów (komputerów stacjonarnych, "
"tabletów i urządzeń mobilnych)."

#: data/app.metainfo.xml.in:32
msgid "Gaussian blurred cover as background, follows GNOME light/dark mode."
msgstr ""
"Rozmycie gaussowskie jako tło, współpracujące z trybem jasnym/ciemnym "
"środowiska GNOME."

#: data/app.metainfo.xml.in:33
msgid ""
"Supports creating and editing playlists, drag cover to change order or add "
"to another playlist."
msgstr ""
"Wspiera tworzenie playlist, przeciąganie okładek, aby zmienić kolejność bądź "
"dodać do innej playlisty.  "

#: data/app.metainfo.xml.in:34
msgid "Supports drag and drop with other apps."
msgstr "Obsługuje przeciąganie z innych aplikacji."

#: data/app.metainfo.xml.in:35
msgid "Supports audio peaks visualizer."
msgstr "Obsługuje wizualizator szczytów dźwiękowych."

#: data/app.metainfo.xml.in:36
msgid "Supports gapless playback."
msgstr "Obsługuje odtwarzanie bez przerw"

#: data/app.metainfo.xml.in:37
msgid "Supports normalizing volume with ReplayGain."
msgstr "Obsługuje normalizację głośności za pomocą ReplayGain."

#: data/app.metainfo.xml.in:38
msgid "Supports specified audio sink."
msgstr "Obsługuje różne źródła dźwięku."

#: data/app.metainfo.xml.in:39
msgid "Supports MPRIS control."
msgstr "Obsługuje kontrolę MPRIS."

